<?xml version="1.0" encoding="UTF-8"?>
<project>
  <name>pascal_bindgen</name>
  <version>1.0.0</version>
  <author>andrew</author>
  <license>BSD-3-Clause</license>

  <build>
    <projectType>application</projectType>
    <mainSource>Main.pas</mainSource>
    <executableName>pascal_bindgen</executableName>
    <outputDirectory>target</outputDirectory>

    <compilerOptions>
      <option>-k--allow-shlib-undefined</option>
      <option>-k-l:libclang-17.so.1</option>
      <option>-k--dynamic-linker=/lib64/ld-linux-x86-64.so.2</option>
    </compilerOptions>
  </build>

  <test>
    <testSource>TestRunner.pas</testSource>
    <frameworkOptions>
      <option>--all --format=plain</option>
    </frameworkOptions>
  </test>
</project>
