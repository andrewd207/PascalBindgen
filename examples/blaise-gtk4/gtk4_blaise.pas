 * %G_IO_ERROR_FAILED.
 *
 * See also #GPollableReturn for a cheaper way of returning
 * %G_IO_ERROR_WOULD_BLOCK to callers without allocating a #GError.
 **/ *)
  GIOErrorEnum = Cardinal;  { gioenums.h:541 }
