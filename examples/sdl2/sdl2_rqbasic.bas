DECLARE FUNCTION SDL_EventState LIB "SDL2" ALIAS "SDL_EventState" (_type AS DWORD, state AS INTEGER) AS BYTE
'/**
' * Allocate a set of user-defined events, and return the beginning event
' * number for that set of events.
