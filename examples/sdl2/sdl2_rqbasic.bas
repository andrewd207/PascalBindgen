' *                locked area
' * \returns 0 on success, or -1 if the texture is not valid or was not created
' *          with `SDL_TEXTUREACCESS_STREAMING`
' *
' * \since This function is available since SDL 2.0.12.
' *
' * \sa SDL_LockTexture
' * \sa SDL_UnlockTexture
' */
DECLARE FUNCTION SDL_LockTextureToSurface LIB "SDL2" ALIAS "SDL_LockTextureToSurface" (texture AS PSDL_Texture, rect AS PSDL_Rect, surface AS POINTER) AS INTEGER
'/**
