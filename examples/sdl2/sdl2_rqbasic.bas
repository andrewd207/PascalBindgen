DECLARE FUNCTION SDL_ConvertPixels LIB "SDL2" ALIAS "SDL_ConvertPixels" (width AS INTEGER, height AS INTEGER, src_format AS DWORD, src AS POINTER, src_pitch AS INTEGER, dst_format AS DWORD, dst AS POINTER, dst_pitch AS INTEGER) AS INTEGER
