DECLARE FUNCTION SDL_LowerBlit LIB "SDL2" ALIAS "SDL_LowerBlit" (src AS PSDL_Surface, srcrect AS PSDL_Rect, dst AS PSDL_Surface, dstrect AS PSDL_Rect) AS INTEGER
