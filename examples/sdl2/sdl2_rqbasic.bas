DECLARE FUNCTION SDL_UpdateTexture LIB "SDL2" ALIAS "SDL_UpdateTexture" (texture AS PSDL_Texture, rect AS PSDL_Rect, pixels AS POINTER, pitch AS INTEGER) AS INTEGER
'/**
