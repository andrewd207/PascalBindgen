' *
' * \since This function is available since SDL 2.0.0.
' *
' * \sa SDL_RenderGetLogicalSize
' */
DECLARE FUNCTION SDL_RenderSetLogicalSize LIB "SDL2" ALIAS "SDL_RenderSetLogicalSize" (renderer AS PSDL_Renderer, w AS INTEGER, h AS INTEGER) AS INTEGER
'/**
