DECLARE FUNCTION SDL_ConvertSurface LIB "SDL2" ALIAS "SDL_ConvertSurface" (src AS PSDL_Surface, fmt AS PSDL_PixelFormat, flags AS DWORD) AS PSDL_Surface
'/**
