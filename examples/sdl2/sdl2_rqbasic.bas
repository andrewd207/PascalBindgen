DECLARE FUNCTION SDL_ConvertSurfaceFormat LIB "SDL2" ALIAS "SDL_ConvertSurfaceFormat" (src AS PSDL_Surface, pixel_format AS DWORD, flags AS DWORD) AS PSDL_Surface
'/**
