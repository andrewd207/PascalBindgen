' */
DECLARE FUNCTION SDL_AudioStreamPut LIB "SDL2" ALIAS "SDL_AudioStreamPut" (stream AS P_SDL_AudioStream, buf AS POINTER, len AS INTEGER) AS INTEGER
'/**
' * Get converted/resampled data from the stream
