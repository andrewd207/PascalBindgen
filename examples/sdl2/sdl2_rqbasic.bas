' *
' * \since This function is available since SDL 2.0.0.
' *
' * \sa SDL_GetCurrentDisplayMode
' * \sa SDL_GetDisplayMode
' * \sa SDL_SetWindowDisplayMode
' */
DECLARE FUNCTION SDL_GetDesktopDisplayMode LIB "SDL2" ALIAS "SDL_GetDesktopDisplayMode" (displayIndex AS INTEGER, mode AS PSDL_DisplayMode) AS INTEGER
'/**
' * Get information about the current display mode.
' *
' * There's a difference between this function and SDL_GetDesktopDisplayMode()
' * when SDL runs fullscreen and has changed the resolution. In that case this
' * function will return the current display mode, and not the previous native
' * display mode.
' *
' * \param displayIndex the index of the display to query
' * \param mode an SDL_DisplayMode structure filled in with the current display
' *             mode
' * \returns 0 on success or a negative error code on failure; call
