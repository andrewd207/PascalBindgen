' */
DECLARE FUNCTION SDL_CreateCursor LIB "SDL2" ALIAS "SDL_CreateCursor" (data AS POINTER, mask AS POINTER, w AS INTEGER, h AS INTEGER, hot_x AS INTEGER, hot_y AS INTEGER) AS PSDL_Cursor
'/**
' * Create a color cursor.
