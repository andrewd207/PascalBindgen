' * \since This function is available since SDL 2.0.0.
' *
' * \sa SDL_GetDisplayMode
' * \sa SDL_GetNumDisplayModes
' */
DECLARE FUNCTION SDL_GetClosestDisplayMode LIB "SDL2" ALIAS "SDL_GetClosestDisplayMode" (displayIndex AS INTEGER, mode AS PSDL_DisplayMode, closest AS PSDL_DisplayMode) AS PSDL_DisplayMode
'/**
