' *          SDL_GetError() for more information.
' *
' * \since This function is available since SDL 2.0.0.
' *
' * \sa SDL_RWclose
' * \sa SDL_RWFromConstMem
' * \sa SDL_RWFromFile
' * \sa SDL_RWFromFP
' * \sa SDL_RWFromMem
' * \sa SDL_RWread
' * \sa SDL_RWseek
' * \sa SDL_RWtell
