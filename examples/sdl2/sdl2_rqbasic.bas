DECLARE FUNCTION SDL_SoftStretch LIB "SDL2" ALIAS "SDL_SoftStretch" (src AS PSDL_Surface, srcrect AS PSDL_Rect, dst AS PSDL_Surface, dstrect AS PSDL_Rect) AS INTEGER
