DECLARE FUNCTION SDL_UpdateYUVTexture LIB "SDL2" ALIAS "SDL_UpdateYUVTexture" (texture AS PSDL_Texture, rect AS PSDL_Rect, Yplane AS POINTER, Ypitch AS INTEGER, Uplane AS POINTER, Upitch AS INTEGER, Vplane AS POINTER, Vpitch AS INTEGER) AS INTEGER
