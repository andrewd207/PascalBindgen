DECLARE FUNCTION SDL_GetNumDisplayModes LIB "SDL2" ALIAS "SDL_GetNumDisplayModes" (displayIndex AS INTEGER) AS INTEGER
'/**
' * Get information about a specific display mode.
' *
' * The display modes are sorted in this priority:
